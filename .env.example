# Lemonade Store GAIA Agents — environment config
# Copy to .env and adjust paths for your install.
# All agents run offline — no cloud keys needed.

# Lemonade NPU server (default: http://localhost:13305/api/v1)
LEMONADE_BASE_URL=http://localhost:13305/api/v1

# Model served by Lemonade (default: Gemma-4-E4B-it-GGUF)
# Set to your preferred loaded model, e.g. Qwen3-4B-GGUF
LEMONADE_MODEL=Gemma-4-E4B-it-GGUF

# Department data paths — point each agent at its repo/data
CASHIER_EVENTS_PATH=/home/bcloud/lemonade-cashier/data/events.jsonl
CASHIER_DOCS_PATH=/home/bcloud/lemonade-cashier

INVENTORY_DB_PATH=/home/bcloud/lemonade-inventory/data/inventory.db
INVENTORY_DOCS_PATH=/home/bcloud/lemonade-inventory

ACCOUNTING_REPORTS_PATH=/home/bcloud/lemonade-accounting/data
ACCOUNTING_DOCS_PATH=/home/bcloud/lemonade-accounting

MARKETEER_CAMPAIGNS_PATH=/home/bcloud/lemonade-marketeer/data
MARKETEER_DOCS_PATH=/home/bcloud/lemonade-marketeer

SUPPLIER_ORDERS_PATH=/home/bcloud/lemonade-supplier/data
SUPPLIER_DOCS_PATH=/home/bcloud/lemonade-supplier

REPORTS_DATA_PATH=/home/bcloud/lemonade-reports/data
REPORTS_DOCS_PATH=/home/bcloud/lemonade-reports

SECURITY_AUDIT_PATH=/home/bcloud/lemonade-security/data/audit.jsonl
SECURITY_AIBOM_PATH=/home/bcloud/lemonade-security/data/aibom.json
SECURITY_DOCS_PATH=/home/bcloud/lemonade-security
